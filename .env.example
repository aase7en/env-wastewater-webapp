# Copy to .env and fill in real values. Never commit .env.
# All keys here are placeholders/examples.
#
# RECOMMENDED (multi-device setup): instead of editing .env directly, put the
# canonical secrets in Google Drive and let the app load from there. See
# CONTRIBUTING.md "Secret storage across devices".

# Supabase Postgres connection string (ENV_DB project gllqtbyofrcjzmbnfoeh, ap-southeast-1).
# Use the asyncpg driver prefix and transaction pooler (port 6543) for async SQLAlchemy.
SUPABASE_DB_URL=postgresql+asyncpg://postgres.gllqtbyofrcjzmbnfoeh:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Supabase JWT secret — used to verify user access tokens issued by Supabase Auth.
# Find it: Supabase dashboard → Project Settings → API → JWT Settings → JWT Secret.
# Leave blank to run in AUTH_STUB_MODE=true (mock auth, dev only).
SUPABASE_JWT_SECRET=

# Auth mode. "jwt" verifies real Supabase tokens; "stub" returns a fixed mock user
# (useful for local dev before real users exist in auth.users).
AUTH_MODE=stub

# When AUTH_MODE=stub, this user is returned for every authenticated request.
STUB_USER_EMAIL=staff@example.local
STUB_USER_ROLE=staff

# App
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000
