# Copy to .env and fill in real values. Never commit .env.
# All keys here are placeholders/examples.
#
# RECOMMENDED (multi-device setup, P6.5): put the canonical secrets in Google
# Drive (A-Wiki-Data/secrets/) and let the config loader read from there.
# Two files:
#   secrets/global.env                  — AI keys + universal tokens
#   secrets/env-wastewater-webapp.env   — this repo: SUPABASE_DB_URL, PAT
# Then make local .env a one-line stub: __LOAD_FROM_DRIVE__=true
# See CONTRIBUTING.md "Secret storage across devices" for full setup.

# Supabase Postgres connection string (ENV_DB project gllqtbyofrcjzmbnfoeh).
# Use the asyncpg driver prefix. Direct host (db.<ref>.supabase.co) for newer
# free-tier projects; transaction pooler (port 6543) for older ones.
SUPABASE_DB_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.gllqtbyofrcjzmbnfoeh.supabase.co:5432/postgres

# Supabase Personal Access Token — used by scripts/introspect_schema_api.py to
# query the DB over HTTPS (Management API), working around the IPv6-only direct
# host on free-tier-new projects. Generate at:
#   https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Supabase JWT secret — used to verify user access tokens issued by Supabase Auth.
# Find it: Supabase dashboard → Project Settings → API → JWT Settings → JWT Secret.
# Leave blank to run in AUTH_MODE=stub (mock auth, dev only).
SUPABASE_JWT_SECRET=

# Auth mode. "jwt" verifies real Supabase tokens; "stub" returns a fixed mock user
# (useful for local dev before real users exist in auth.users).
AUTH_MODE=stub

# When AUTH_MODE=stub, this user is returned for every authenticated request.
STUB_USER_EMAIL=staff@example.local
STUB_USER_ROLE=staff

# App
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000
