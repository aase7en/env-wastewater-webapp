# Vite env vars (VITE_ prefix required — exposed to client build).
# These are PUBLIC publishable values (RLS-gated in Supabase); safe to embed.
# Source of truth: Drive secrets/env-wastewater-webapp.env
#
# Copy this file to .env and fill in real values from Supabase dashboard
# (Project Settings → API → Project URL + anon/publishable key).

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_YOUR_KEY_HERE
